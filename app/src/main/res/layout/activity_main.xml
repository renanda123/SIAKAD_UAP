<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FDF8FF">

    <!-- Bagian Atas Sampai Menu Grid (Scrollable) -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@id/layoutBottomLogoutMain"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="16dp">

            <!-- Header Banner Ungu UAP -->
            <View
                android:id="@+id/viewHeaderMain"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:background="@color/primary"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tvSiakadTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginTop="20dp"
                android:text="SIAKAD UAP"
                android:textColor="#E9D5FF"
                android:textSize="14sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tvNamaMahasiswa"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginTop="4dp"
                android:text="Renanda Setiawan"
                android:textColor="@color/white"
                android:textSize="22sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvSiakadTitle" />

            <TextView
                android:id="@+id/tvDetailMahasiswa"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginTop="4dp"
                android:text="NPM: 230201023  |  Semester 5"
                android:textColor="#F3E8FF"
                android:textSize="13sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvNamaMahasiswa" />

            <TextView
                android:id="@+id/tvProdiMahasiswa"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginTop="20dp"
                android:text="S1 Teknik Informatika"
                android:textColor="#F3E8FF"
                android:textSize="13sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvDetailMahasiswa" />

            <!-- Area Putih Konten Menu -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="-24dp"
                style="?attr/materialCardViewStyle"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="28dp"
                app:strokeWidth="0dp"
                app:layout_constraintTop_toBottomOf="@id/viewHeaderMain">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Menu Akademik"
                        android:textColor="#111827"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="16dp"/>

                    <!-- Grid RecyclerView -->
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvMenu"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bagian Paling Bawah: Tombol Logout Pinned Permanen di Dashboard -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/layoutBottomLogoutMain"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        style="?attr/materialCardViewStyle"
        app:cardBackgroundColor="@color/white"
        app:cardCornerRadius="0dp"
        app:cardElevation="16dp"
        app:strokeWidth="0dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLogoutMain"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_margin="16dp"
            android:text="Keluar Aplikasi"
            android:textAllCaps="false"
            android:textColor="#B91C1C"
            android:textSize="15sp"
            android:textStyle="bold"
            app:backgroundTint="#FEE2E2"
            app:cornerRadius="12dp"
            app:strokeColor="#FCA5A5"
            app:strokeWidth="1dp" />
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>