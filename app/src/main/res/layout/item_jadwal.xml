<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="16dp"
    android:layout_marginEnd="16dp"
    android:layout_marginTop="8dp"
    android:layout_marginBottom="8dp"
    style="?attr/materialCardViewStyle"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:strokeColor="#F1F5F9"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <!-- Bagian Kiri: Kapsul Hari & Jam (Timeline Badge) -->
        <LinearLayout
            android:layout_width="85dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingEnd="12dp"
            android:layout_marginEnd="4dp">

            <!-- Badge Nama Hari -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardHariJadwal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="?attr/materialCardViewStyle"
                app:cardBackgroundColor="#F3E8FF"
                app:cardCornerRadius="8dp"
                app:strokeWidth="0dp">

                <TextView
                    android:id="@+id/tvHariJadwal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:paddingVertical="4dp"
                    android:text="Senin"
                    android:textColor="#7C3AED"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </com.google.android.material.card.MaterialCardView>

            <!-- Teks Jam Kuliah -->
            <TextView
                android:id="@+id/tvJamJadwal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="08.00"
                android:textColor="#4B5563"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvJamSelesaiJadwal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="10.30 WIB"
                android:textColor="#9CA3AF"
                android:textSize="10sp" />
        </LinearLayout>

        <!-- Garis Pembatas Vertikal (Timeline Divider) -->
        <View
            android:layout_width="1dp"
            android:layout_height="50dp"
            android:background="#E2E8F0" />

        <!-- Bagian Kanan: Detail Informasi Kelas -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="16dp">

            <!-- Nama Mata Kuliah -->
            <TextView
                android:id="@+id/tvNamaMatkulJadwal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Mobile Programming"
                android:textColor="#111827"
                android:textSize="15sp"
                android:textStyle="bold" />

            <!-- Informasi Tambahan (Ruangan & Dosen) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="6dp"
                android:gravity="center_vertical">

                <!-- Label Ruangan -->
                <TextView
                    android:id="@+id/tvRuanganJadwal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="#F1F5F9"
                    android:paddingHorizontal="6dp"
                    android:paddingVertical="2dp"
                    android:text="Lab Komputer 2"
                    android:textColor="#475569"
                    android:textSize="11sp"
                    android:textFontWeight="500" /> <!-- Menggunakan berat 500 untuk Medium -->

                <!-- Titik Pemisah -->
                <View
                    android:layout_width="4dp"
                    android:layout_height="4dp"
                    android:layout_marginHorizontal="8dp"
                    android:background="#9CA3AF" />

                <!-- SKS -->
                <TextView
                    android:id="@+id/tvSksJadwal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="3 SKS"
                    android:textColor="#6B7280"
                    android:textSize="11sp" />
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>